{
  "name": "nyc-apt-radar",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run tests/radar-loop.test.ts",
    "reset": "tsx scripts/reset.ts",
    "doctor": "tsx scripts/doctor.ts",
    "agent:run": "tsx scripts/loop-once.ts",
    "agent:dry-run": "tsx scripts/loop-once.ts --no-notify",
    "agent:install": "tsx scripts/install-launchd.ts",
    "agent:uninstall": "tsx scripts/uninstall-launchd.ts",
    "agent:install:systemd": "tsx scripts/install-systemd.ts",
    "agent:uninstall:systemd": "tsx scripts/uninstall-systemd.ts",
    "agent:logs": "tsx scripts/logs.ts",
    "events": "tsx scripts/events.ts",
    "searches": "tsx scripts/searches.ts",
    "ntfy:setup": "tsx scripts/setup-ntfy.ts",
    "notify:test": "tsx scripts/notify-test.ts",
    "notifications": "tsx scripts/notifications.ts",
    "radar": "tsx scripts/radar-cli.ts",
    "intake": "tsx scripts/intake.ts",
    "listing:update": "tsx scripts/update-listing.ts",
    "listing:status": "tsx scripts/update-status.ts",
    "listing:draft": "tsx scripts/draft.ts"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^3.2.6"
  }
}
