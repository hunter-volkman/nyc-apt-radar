    "agent:dry-run": "tsx scripts/loop-once.ts --no-notify",
    "agent:recommendations": "tsx scripts/agent-recommendations.ts",
    "agent:trace": "tsx scripts/agent-trace.ts",
    "agent:review": "tsx scripts/operator-review.ts",
    "agent:verify": "tsx scripts/agent-verify.ts",
    "notify:test": "tsx scripts/notify-test.ts",
    "radar": "tsx scripts/radar-cli.ts"
