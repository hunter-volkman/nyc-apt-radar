{
  "name": "nyc-apt-radar",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "doctor": "tsx scripts/doctor.ts",
