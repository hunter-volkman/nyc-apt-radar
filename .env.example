# Optional parser/OpenAI extraction path.
# OPENAI_API_KEY=

# Apartment Radar local database and source-message scanner.
# APARTMENT_RADAR_DATABASE_PATH=data/apartment-radar.sqlite
# APARTMENT_RADAR_SOURCE_DIR=data/source-events
# APARTMENT_RADAR_WATCH_INTERVAL_MINUTES=10

# Optional iOS push via the ntfy app. Use a long, unguessable topic.
# APARTMENT_RADAR_NOTIFY_CHANNEL=ntfy
# APARTMENT_RADAR_NTFY_TOPIC=apartment-radar-long-random-secret
# APARTMENT_RADAR_NTFY_BASE_URL=https://ntfy.sh

# Optional Mapbox display shell. Transit commute scoring is not implemented here.
# NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=
