# Optional parser/OpenAI extraction path.
# OPENAI_API_KEY=

# NYC Apt Radar local database and source-message scanner.
# NYC_APT_RADAR_DATABASE_PATH=data/nyc-apt-radar.sqlite
# NYC_APT_RADAR_SOURCE_DIR=data/source-events
# NYC_APT_RADAR_WATCH_INTERVAL_MINUTES=10

# Optional iOS push via the ntfy app. Use a long, unguessable topic.
# NYC_APT_RADAR_NOTIFY_CHANNEL=ntfy
# NYC_APT_RADAR_NTFY_TOPIC=nyc-apt-radar-long-random-secret
# NYC_APT_RADAR_NTFY_BASE_URL=https://ntfy.sh
