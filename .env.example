# Local SQLite path.
# Copy this file to .env.local for local runs. Shell variables take precedence.
# NYC_APT_RADAR_DATABASE_PATH=data/nyc-apt-radar-loop.sqlite

# Discovery sources.
# Default source directory: data/source-events
# NYC_APT_RADAR_SOURCES_PATH=data/sources.json
# NYC_APT_RADAR_SOURCE_URLS=
# NYC_APT_RADAR_FETCH_TIMEOUT_MS=15000
# NYC_APT_RADAR_SOURCE_CONCURRENCY=4
# NYC_APT_RADAR_WATCH_INTERVAL_MINUTES=10

# Search profile and N commute targets.
# Copy data/preferences.example.json to data/preferences.json, then edit.
# NYC_APT_RADAR_PREFERENCES_PATH=data/preferences.json

# Push notifications for hot matches.
# NYC_APT_RADAR_NTFY_TOPIC=nyc-apt-radar-long-random-secret
# NYC_APT_RADAR_NTFY_BASE_URL=https://ntfy.sh
# NYC_APT_RADAR_NTFY_TIMEOUT_MS=10000

# OpenAI Responses API for unstructured listing-text extraction.
# Ranking, scoring, field finalization, status changes, and outreach sending remain local/manual.
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5.5
# NYC_APT_RADAR_OPENAI_TIMEOUT_MS=20000
